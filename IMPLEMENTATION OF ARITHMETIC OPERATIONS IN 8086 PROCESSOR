PROGRAM 5:A^2-B^2/A-B
------------------------------------------
                OUTPUT 2500AD
.ORG 3000H
DATA SEGMENT
NO1 DB EEH
NO2 DB BBH
ANS1 DW 0000H
ANS2 DW 0000H
ANS3 DW 0000H
ANS4 DB 00H
RES DB 00H
RES1 DB 00H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
START:
        MOV AX,DATA
        MOV DS,AX
        MOV AL,NO1
        MUL AL
        MOV ANS1,AX
        MOV AL,NO2
        MUL AL
        MOV ANS2,AX
        MOV AX,ANS1
        SUB AX,ANS2
        MOV ANS3,AX
        MOV BL,NO1
        SUB BL,NO2
        MOV ANS4,BL
        MOV AX,ANS3
        MOV CL,ANS4
        DIV CL
        MOV RES,AL
        MOV RES1,AH
CODE ENDS
END
