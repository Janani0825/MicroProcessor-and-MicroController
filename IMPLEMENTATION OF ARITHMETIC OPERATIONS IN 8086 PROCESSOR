PROGRAM 1: 16-BIT ADDITION
``````````````````````````````````````````````````````````
                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
NUM1 DW AAAAH
NUM2 DW BBBBH
SUM DW 0000H
CARRY DB 00H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS ,AX
        MOV CL,00H
        MOV AX,NUM1
        MOV BX,NUM2
        ADD AX,BX
        JNC L1
        INC CL
L1: MOV SUM,AX
        MOV CARRY,CL
CODE ENDS
END
