--------------------------------------------------------
1.8-BIT ADDITION
--------------------------------------------------------
.ORG 8000H
START:
        MOV DPTR,#9000H
        MOV R0,#00H
        MOVX A,@DPTR
        MOV R1,A
        INC DPTR
        MOVX A,@DPTR
        ADD A,R1
        JNC L1
        INC R0
L1:
        INC DPTR
        MOVX @DPTR,A
        INC DPTR
        MOV A,R0
        MOVX @DPTR,A
END
